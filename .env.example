# Chest X-Ray Classifier — environment variables
# Copy to .env and fill in your values.

# ── Training mode ─────────────────────────────────────────────────
# subset  → 500-image auto-download for local dev (~200MB)
# full    → complete NIH dataset (~45GB, requires download_nih.py)
# kaggle  → pre-mounted on Kaggle platform
TRAINING_MODE=subset
SUBSET_SIZE=500

# ── Model ────────────────────────────────────────────────────────
BACKBONE=densenet121
# BACKBONE=efficientnet_v2_s

# ── Training ─────────────────────────────────────────────────────
TRAIN_EPOCHS=10
TRAIN_LR=1e-4
TRAIN_BATCH_SIZE_GPU=32
TRAIN_BATCH_SIZE_CPU=8
EARLY_STOP_PATIENCE=5

# ── Grad-CAM ─────────────────────────────────────────────────────
GRADCAM_COLORMAP=jet
GRADCAM_ALPHA=0.4

# ── API ───────────────────────────────────────────────────────────
API_PORT=8000
API_DEBUG=true

# ── Logging ───────────────────────────────────────────────────────
LOG_LEVEL=INFO
